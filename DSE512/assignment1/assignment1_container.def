Bootstrap: docker
From: ubuntu:22.04

%post
    apt-get update && apt-get install -y \
        python3 python3-pip \
        && pip3 install pandas numpy \
        && apt-get clean \
        && rm -rf /var/lib/apt/lists/*

    cat > /usr/local/bin/assignment1_container.sh << 'SCRIPT'
    #!/usr/bin/env bash

set -euo pipefail

echo "hostname=$(hostname)"
echo "timestamp=$(date -Iseconds)"
echo "SLURM_JOB_ID=${SLURM_JOB_ID:-not-set}"
echo "course_container_tag=${course_container_tag:-unset}"
echo "numpy_version=$(python3 -c 'import numpy as n; print(n.__version__)')"
echo "pandas_version=$(python3 -c 'import pandas as p; print(p.__version__)')"

SCRIPT

    chmod +x /usr/local/bin/assignment1_container.sh

%environment
    export course_container_tag="assignment1"

%runscript
    exec /usr/local/bin/assignment1_container.sh "$@"
